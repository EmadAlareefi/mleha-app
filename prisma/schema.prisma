  deliveryNotes    DeliveryNote[]

  @@index([name])
  @@index([accessCode])
  @@index([isActive])
  @@index([orderUserId])
}

model TailorFabricIssue {
  id String @id @default(cuid())

  fabricId String
  fabric   Fabric @relation(fields: [fabricId], references: [id], onDelete: Restrict)
  // Nullable: WAREHOUSE-location ledger rows (warehouse purchases, stock adjustments) have no tailor.
  tailorId String?
  tailor   Tailor? @relation(fields: [tailorId], references: [id], onDelete: Restrict)

  designModelId String?
  designModel   DesignModel? @relation(fields: [designModelId], references: [id], onDelete: SetNull)

  issuedLength    Decimal  @db.Decimal(12, 2)
  unitCostAtIssue Decimal  @default(0) @db.Decimal(10, 2)
  issueDate       DateTime @default(now())
  reference       String?
  status          String   @default("with_tailor")

  plannedDressCount Int?
  size              String? // optional dress size for this issue/delivery
  componentsIssued  Json? // snapshot: { fabrics:[{fabricId,name,consumption,meters,unitCost}], accessories:[{accessoryId,name,qty,unitPrice}] }

  deliveredDressCount Int?
  consumedLength      Decimal?  @db.Decimal(12, 2)
  returnedLength      Decimal?  @db.Decimal(12, 2)
  tailoringCost       Decimal?  @db.Decimal(12, 2)
  embroideryCost      Decimal?  @db.Decimal(12, 2)
  extraCost           Decimal?  @db.Decimal(12, 2)
  deliveryDate        DateTime?

  // Generalized fabric-movement ledger (see FabricMovementType/FabricLocationType). Pre-migration
  // rows default to LEGACY_ISSUE with quantityDelta left null; new code only reads/writes these columns.
  movementType          FabricMovementType @default(LEGACY_ISSUE)
  location              FabricLocationType @default(TAILOR)
  quantityDelta         Decimal?           @db.Decimal(12, 2) // signed meters; +in, -out, at `location`
  transferGroupId       String? // pairs the two legs (warehouse debit + tailor credit) of one custody transfer
  purchaseInvoiceItemId String? // set when movementType is *_PURCHASE, points at the originating bill line
  deliveryNoteId        String?
  deliveryNote          DeliveryNote?      @relation(fields: [deliveryNoteId], references: [id], onDelete: SetNull)

  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fabricId])
  @@index([tailorId])
  @@index([designModelId])
  @@index([status])
  @@index([issueDate])
  @@index([deliveryDate])
  @@index([movementType])
  @@index([location, tailorId])
  @@index([transferGroupId])
  @@index([deliveryNoteId])
}

