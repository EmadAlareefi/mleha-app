  // Real login identity for this tailor (replaces the accessCode gate).
  orderUserId String?    @unique
  orderUser   OrderUser? @relation(fields: [orderUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issues           TailorFabricIssue[]
