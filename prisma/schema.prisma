  id              String    @id @default(cuid())
  deliveryAgentId String
  deliveryAgent   OrderUser @relation("AgentWalletTransactions", fields: [deliveryAgentId], references: [id], onDelete: Cascade)

  type          DeliveryAgentWalletTransactionType
  amount        Decimal                            @db.Decimal(10, 2)
  referenceId   String?
  referenceType String?
  notes         String?                            @db.Text
  metadata      Json?

  createdAt     DateTime   @default(now())
  createdById   String?
  createdByName String?
  createdBy     OrderUser? @relation("WalletTransactionsCreated", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([referenceType, referenceId])
  @@index([deliveryAgentId])
  @@index([type])
}
