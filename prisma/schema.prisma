// Location a fabric movement/ledger row is attributed to: the main warehouse, or a specific tailor's own holding.
enum FabricLocationType {
  WAREHOUSE
  TAILOR
}

// What kind of event a TailorFabricIssue ledger row represents (generalizes the original
// "admin issues fabric to a tailor" meaning into a full movement ledger).
enum FabricMovementType {
  WAREHOUSE_PURCHASE // bill entered by the warehouse; stock arrives at the warehouse
  TAILOR_PURCHASE // bill entered by a tailor for fabric they bought themselves; arrives already at that tailor
  ISSUE_TO_TAILOR // warehouse pushes fabric to a tailor (custody transfer, net-zero on Fabric.stockLength)
  RETURN_TO_WAREHOUSE // tailor returns leftover fabric to the warehouse (custody transfer)
  CONSUMPTION // fabric consumed manufacturing dresses (finalized at delivery-note acceptance)
  STOCK_ADJUSTMENT // manual stock-count correction entered by the warehouse or a tailor
  LEGACY_ISSUE // pre-migration rows written by the old issue/receive flow; quantityDelta is not populated
}

enum DeliveryNoteStatus {
  DRAFT
  SUBMITTED
  ACCEPTED
  REJECTED
}

